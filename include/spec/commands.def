// include/spec/commands.def
// CMD(Name, WireId, Op, "NAME", FeatureGroup, Flags, SinceKvn, SchemaId, Handler)

CMD(Ping,        1, Op::Ping,        "PING",        FeatureGroup::Proto,
    CommandFlags::Read | CommandFlags::Idempotent, 1, SchemaId::None, handle_ping)

CMD(Get,         2, Op::Get,         "GET",         FeatureGroup::CoreKV,
    CommandFlags::Read | CommandFlags::Idempotent, 1, SchemaId::Key,  handle_get)

CMD(Set,         3, Op::Set,         "SET",         FeatureGroup::CoreKV,
    CommandFlags::Write | CommandFlags::Idempotent, 1, SchemaId::Set,  handle_set)

CMD(Del,         4, Op::Del,         "DEL",         FeatureGroup::CoreKV,
    CommandFlags::Write | CommandFlags::Idempotent, 1, SchemaId::Key,  handle_del)

CMD(Size,        5, Op::Size,        "SIZE",        FeatureGroup::CoreKV,
    CommandFlags::Read | CommandFlags::Idempotent, 1, SchemaId::None, handle_size)

CMD(Incr,        6, Op::Incr,        "INCR",        FeatureGroup::Numeric,
    CommandFlags::Write,                            1, SchemaId::Key,  handle_incr)

CMD(IncrBy,      7, Op::IncrBy,      "INCRBY",      FeatureGroup::Numeric,
    CommandFlags::Write,                            1, SchemaId::KeyI64, handle_incrby)

CMD(IncrByFloat, 8, Op::IncrByFloat, "INCRBYFLOAT", FeatureGroup::Numeric,
    CommandFlags::Write,                            1, SchemaId::KeyF64, handle_incrbyfloat)

CMD(PExpire,     9, Op::PExpire,     "PEXPIRE",     FeatureGroup::Ttl,
    CommandFlags::Write,                            1, SchemaId::KeyI64, handle_pexpire)

CMD(PTtl,       10, Op::PTtl,        "PTTL",        FeatureGroup::Ttl,
    CommandFlags::Read | CommandFlags::Idempotent,  1, SchemaId::Key,  handle_pttl)

CMD(Info,       11, Op::Info,       "INFO",       FeatureGroup::Admin,
    CommandFlags::Read | CommandFlags::Admin | CommandFlags::Idempotent,
    1, SchemaId::None, handle_info)

CMD(Caps,       12, Op::Caps,       "CAPS",       FeatureGroup::Admin,
    CommandFlags::Read | CommandFlags::Admin | CommandFlags::Idempotent,
    1, SchemaId::None, handle_caps)

CMD(Commands,   13, Op::Commands,   "COMMANDS",   FeatureGroup::Admin,
    CommandFlags::Read | CommandFlags::Admin | CommandFlags::Idempotent,
    1, SchemaId::None, handle_commands)